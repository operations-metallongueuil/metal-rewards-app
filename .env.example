# PostgreSQL connection string (get this from Neon: https://neon.tech)
DATABASE_URL="postgresql://user:password@host.neon.tech/metal_rewards?sslmode=require"

# A random secret string — used to validate session cookies
# Generate one with: openssl rand -hex 32
SESSION_TOKEN="replace-with-a-random-secret-string"

# The shared login password for the app
APP_PASSWORD="your-secure-password-here"
